","name":"word_timings","type":"JUNO_WORD_TIMINGS","link":1},{"localized_name":"style","name":"style","shape":7,"type":"JUNO_CAPTION_STYLE","link":4},{"localized_name":"fps","name":"fps","type":"FLOAT","widget":{"name":"fps"},"link":null},{"localized_name":"max_words","name":"max_words","type":"INT","widget":{"name":"max_words"},"link":null},{"localized_name":"pause_threshold","name":"pause_threshold","type":"FLOAT","widget":{"name":"pause_threshold"},"link":null},{"localized_name":"time_offset","name":"time_offset","shape":7,"type":"FLOAT","widget":{"name":"time_offset"},"link":null},{"localized_name":"speed_factor","name":"speed_factor","shape":7,"type":"FLOAT","widget":{"name":"speed_factor"},"link":null},{"localized_name":"word_padding_before","name":"word_padding_before","shape":7,"type":"FLOAT","widget":{"name":"word_padding_before"},"link":null},{"localized_name":"word_padding_after","name":"word_padding_after","shape":7,"type":"FLOAT","widget":{"name":"word_padding_after"},"link":null},{"localized_name":"track_spacing","name":"track_spacing","shape":7,"type":"FLOAT","widget":{"name":"track_spacing"},"link":null}],"outputs":[{"localized_name":"images","name":"images","type":"IMAGE","slot_index":0,"links":[6]}],"properties":{"aux_id":"clg236/juno-comfyui-nodes","ver":"b31ab01e55a41cd59fb9fc2cb00f9e327fefc89e","Node name for S&R":"JunoRenderCaptions"},"widgets_values":[30,3,0.3,0,1,0,0,0.12],"color":"#232","bgcolor":"#353"},{"id":8,"type":"Note","pos":[-468,-192],"size":[420,744],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["HOW TO USE THIS WORKFLOW — TTS to Captions\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nThis workflow generates speech from text, then overlays animated captions onto video.\n\n1. LOAD VIDEO: Select your video file in the VHS Load Video node.\n\n2. TYPE TEXT: Enter your script in the Juno TTS (Edge) node.\n   Choose a voice (20+ English voices available, e.g. en-US-GuyNeural).\n   The node generates audio AND word-level timestamps automatically.\n\n3. STYLE (optional): Use the Caption Style node to pick a preset\n   (Hormozi, MrBeast, Netflix, etc.) or customize colors, font, stroke, and position.\n\n4. RENDER: Juno Render Captions overlays animated word-by-word highlights\n   onto your video frames. Adjust max_words, pause_threshold, and timing offsets.\n\n5. PREVIEW: Audio preview plays the TTS output. Video Combine exports the final MP4.\n\nTIP: Match the fps in Render Captions to your video's frame rate for accurate sync."],"color":"#353","bgcolor":"#464"}],"links":[[1,1,1,4,1,"JUNO_WORD_TIMINGS"],[2,2,0,4,0,"IMAGE"],[3,1,0,6,0,"AUDIO"],[4,3,0,4,2,"JUNO_CAPTION_STYLE"],[6,4,0,7,0,"IMAGE"]],"groups":[{"id":1,"title":"1. Generate Speech","bounding":[-24,-216,456,1116],"color":"#3f789e","font_size":24,"flags":{}},{"id":2,"title":"2. Render Captions","bounding":[504,168,432,804],"color":"#3b8c6e","font_size":24,"flags":{}},{"id":3,"title":"3. Preview","bounding":[1020,168,348,504],"color":"#8c6e3b","font_size":24,"flags":{}}],"config":{},"extra":{"ds":{"scale":0.5179653219170659,"offset":[1632.5766750135315,542.9604476145236]}},"version":0.4}