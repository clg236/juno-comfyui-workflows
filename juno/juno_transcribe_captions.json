},{"localized_name":"highlight_color_3","name":"highlight_color_3","type":"STRING","widget":{"name":"highlight_color_3"},"link":null},{"localized_name":"highlight_color_4","name":"highlight_color_4","type":"STRING","widget":{"name":"highlight_color_4"},"link":null},{"localized_name":"stroke_color","name":"stroke_color","type":"STRING","widget":{"name":"stroke_color"},"link":null},{"localized_name":"stroke_width","name":"stroke_width","type":"INT","widget":{"name":"stroke_width"},"link":null},{"localized_name":"shadow_color","name":"shadow_color","type":"STRING","widget":{"name":"shadow_color"},"link":null},{"localized_name":"shadow_opacity","name":"shadow_opacity","type":"FLOAT","widget":{"name":"shadow_opacity"},"link":null},{"localized_name":"shadow_blur","name":"shadow_blur","type":"FLOAT","widget":{"name":"shadow_blur"},"link":null},{"localized_name":"anim_duration","name":"anim_duration","type":"FLOAT","widget":{"name":"anim_duration"},"link":null},{"localized_name":"y_position","name":"y_position","type":"FLOAT","widget":{"name":"y_position"},"link":null},{"localized_name":"uppercase","name":"uppercase","type":"BOOLEAN","widget":{"name":"uppercase"},"link":null}],"outputs":[{"localized_name":"style","name":"style","type":"JUNO_CAPTION_STYLE","links":[7]}],"properties":{"aux_id":"clg236/juno-comfyui-nodes","ver":"b31ab01e55a41cd59fb9fc2cb00f9e327fefc89e","Node name for S&R":"JunoCaptionStyle"},"widgets_values":["Custom","/workspace/runpod-slim/ComfyUI/custom_nodes/juno-comfyui-nodes/fonts/Anton-Regular.ttf",120,"#FFFFFF","#00FFFF","#00FF00","#FFFF00","#FF4444","#000000",8,"#000000",0.6,6,0.15,0.45,true]},{"id":8,"type":"Note","pos":[-300,-156],"size":[920,220],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["HOW TO USE THIS WORKFLOW — Transcribe Audio to Captions\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nThis workflow transcribes existing audio and overlays animated captions onto video.\n\n1. LOAD AUDIO: Select your audio file (.wav, .mp3) in the Load Audio node.\n   OR use audio extracted from the video (connect VHS Load Video audio output).\n\n2. LOAD VIDEO: Select your video file in VHS Load Video.\n\n3. TRANSCRIBE: Juno Transcribe Audio uses Whisper to extract word-level timestamps.\n   - model_size: \"base\" is fast, \"large-v3\" is most accurate\n   - device: \"cuda\" for GPU acceleration\n\n4. STYLE (optional): Use Caption Style to pick a preset or customize.\n   Presets: Hormozi, MrBeast, Netflix, Neon, Pop Color, Podcast, Luxury.\n\n5. RENDER: Juno Render Captions overlays animated word highlights onto your frames.\n   Adjust max_words (words per group), pause_threshold, and timing offsets.\n\n6. EXPORT: VHS Video Combine outputs the final MP4 with original audio.\n\nTIP: For best sync, make sure the audio matches the video duration."],"color":"#353","bgcolor":"#464"}],"links":[[1,1,0,2,0,"AUDIO"],[2,2,0,4,1,"JUNO_WORD_TIMINGS"],[3,3,0,4,0,"IMAGE"],[5,4,0,6,0,"IMAGE"],[6,3,2,6,1,"AUDIO"],[7,7,0,4,2,"JUNO_CAPTION_STYLE"]],"groups":[{"id":1,"title":"1. Load & Transcribe Audio","bounding":[-300,108,756,756],"color":"#3f789e","font_size":24,"flags":{}},{"id":2,"title":"2. Render Captions on Video","bounding":[516,108,468,972],"color":"#3b8c6e","font_size":24,"flags":{}},{"id":3,"title":"3. Preview","bounding":[1260,216,372,480],"color":"#8c6e3b","font_size":24,"flags":{}}],"config":{},"extra":{"ds":{"scale":0.5009040635756473,"offset":[1241.2103204672762,461.28753119757744]}},"version":0.4}